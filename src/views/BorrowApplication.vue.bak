<template>
  <div class="borrow-application">
    <div class="page-header">
      <el-icon class="header-icon"><School /></el-icon>
      <span>预约申请</span>
      <el-button type="primary" size="default" @click="openAnnounce" class="announce-btn">
        <el-icon><Bell /></el-icon>
        公告
      </el-button>
    </div>

    <el-dialog v-model="announceVisible" title="公告" width="60%" :close-on-click-modal="false">
      <div class="announce-content" v-html="renderedContent"></div>
      <template #footer>
        <el-button type="primary" @click="closeAnnounce">我已知悉</el-button>
      </template>
    </el-dialog>

    <!-- Classroom selection dialog -->
    <el-dialog v-model="roomDialogVisible" title="选择教室" width="900px" :close-on-click-modal="false">
      <div class="dialog-tip">为每间教室设置独立的预约时间段，系统会自动检测冲突</div>
      <el-table :data="selectedRooms" style="width: 100%; margin-top: 12px" size="small">
        <el-table-column label="教室" min-width="200">
          <template #default="{ row, $index }">
            <el-select v-model="row.roomId" placeholder="选择教室" filterable style="width: 100%"
              @change="onRoomChange($index)">
              <el-option v-for="room in availableRooms" :key="room.id"
                :label="room.name + (room.location ? ' (' + room.location + ')' : '')"
                :value="room.id" />
            </el-select>
          </template>
        </el-table-column>
        <el-table-column label="预约时间" width="210">
          <template #default="{ row, $index }">
            <el-date-picker v-model="row.brwtime" type="datetime" placeholder="开始时间"
              format="YYYY-MM-DD HH:mm" value-format="YYYY-MM-DD HH:mm" style="width: 100%"
              @change="onTimeChange($index)" />
          </template>
        </el-table-column>
        <el-table-column label="归还时间" width="210">
          <template #default="{ row, $index }">
            <el-date-picker v-model="row.rtuntime" type="datetime" placeholder="结束时间"
              format="YYYY-MM-DD HH:mm" value-format="YYYY-MM-DD HH:mm" style="width: 100%"
              @change="onTimeChange($index)" />
          </template>
        </el-table-column>
        <el-table-column label="状态" width="100">
          <template #default="{ row }">
            <span v-if="row.checking" style="color: #909399">检测中...</span>
            <el-tag v-else-if="row.conflict" type="danger" size="small">冲突</el-tag>
            <el-tag v-else-if="row.roomId && row.brwtime && row.rtuntime" type="success" size="small">可用</el-tag>
            <span v-else style="color: #c0c4cc">—</span>
          </template>
        </el-table-column>
        <el-table-column label="操作" width="70">
          <template #default="{ $index }">
            <el-button type="danger" size="small" @click="removeRoom($index)" :icon="CircleClose" circle />
          </template>
        </el-table-column>
      </el-table>

      <div style="margin-top: 16px">
        <el-button type="primary" @click="addRoom" :icon="Plus">添加教室</el-button>
        <span class="room-count">已选 {{ selectedRooms.length }} 间教室</span>
      </div>

      <template #footer>
        <el-button @click="roomDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="confirmRoomSelection" :disabled="!canConfirm">
          确认选择
        </el-button>
      </template>
    </el-dialog>

    <div v-if="successModalVisible" class="success-modal-overlay" @click="closeSuccessModal">
      <div class="success-modal-content" @click.stop>
        <div class="success-icon">
          <el-icon :size="80" color="#67c23a"><CircleCheck /></el-icon>
        </div>
        <h2 class="success-title">教室预约成功</h2>
        <p class="success-text">您的预约申请已成功提交，请按时使用教室</p>
      </div>
    </div>

    <el-form ref="borrowFormRef" :model="borrowForm" :rules="rules" label-width="80px" class="borrow-form">
      <el-divider content-position="left">
        <el-icon><User /></el-icon>
        个人信息
      </el-divider>

      <el-row :gutter="20">
        <el-col :xs="24" :sm="12" :span="12">
          <el-form-item label="姓名" prop="name">
            <el-input v-model="borrowForm.name" placeholder="请输入姓名">
              <template #prefix><el-icon><User /></el-icon></template>
            </el-input>
          </el-form-item>
        </el-col>
        <el-col :xs="24" :sm="12" :span="12">
          <el-form-item label="学号" prop="studentId">
            <el-input v-model="borrowForm.studentId" placeholder="请输入学号">
              <template #prefix><el-icon><Tickets /></el-icon></template>
            </el-input>
          </el-form-item>
        </el-col>
      </el-row>

      <el-row :gutter="20">
        <el-col :span="24">
          <el-form-item label="手机号" prop="phone">
            <el-input v-model="borrowForm.phone" placeholder="请输入手机号">
              <template #prefix><el-icon><Phone /></el-icon></template>
            </el-input>
          </el-form-item>
        </el-col>
      </el-row>

      <el-divider content-position="left">
        <el-icon><School /></el-icon>
        教室选择
      </el-divider>

      <el-row :gutter="20">
        <el-col :span="24">
          <el-form-item label="教室" prop="roomCount">
            <div class="room-summary" v-if="selectedRooms.length > 0">
              <el-tag v-for="(room, idx) in selectedRooms" :key="idx" size="default" type="primary" class="room-tag">
                {{ getRoomName(room.roomId) }}
                <span class="room-time">{{ room.brwtime }} ~ {{ room.rtuntime }}</span>
              </el-tag>
            </div>
            <el-button type="primary" @click="openRoomDialog">
              <el-icon><Plus /></el-icon>
              {{ selectedRooms.length > 0 ? '修改教室选择' : '选择教室' }}
            </el-button>
          </el-form-item>
        </el-col>
      </el-row>

      <el-row :gutter="20">
        <el-col :span="24">
          <el-form-item label="备注">
            <el-input v-model="borrowForm.remark" type="textarea" :rows="3" placeholder="请输入备注信息（选填）" />
          </el-form-item>
        </el-col>
      </el-row>

      <el-row>
        <el-col :span="24" class="button-group">
          <el-button type="primary" @click="handleSubmit" :loading="loading">
            <el-icon><Check /></el-icon>
            提交申请
          </el-button>
          <el-button @click="handleReset">
            <el-icon><RefreshRight /></el-icon>
            重置
          </el-button>
        </el-col>
      </el-row>
    </el-form>
  </div>
</template>

<script setup>
import { reactive, ref, onMounted, computed } from 'vue'
import { marked } from 'marked'
import { ElMessage, ElMessageBox } from 'element-plus'
import { School, User, Tickets, Phone, Check, RefreshRight, CircleCheck, Bell, Plus, CircleClose } from '@element-plus/icons-vue'

const borrowFormRef = ref()
const loading = ref(false)
const allClassrooms = ref([])
const availableRooms = ref([])
const announceVisible = ref(false)
const announceContent = ref('')
const successModalVisible = ref(false)
const roomDialogVisible = ref(false)
let successModalTimer = null

const renderedContent = computed(() => announceContent.value ? marked(announceContent.value) : '')

const borrowForm = reactive({
  name: '', studentId: '', phone: '', remark: ''
})

const selectedRooms = ref([])

const rules = {
  name: [{ required: true, message: '请输入姓名', trigger: 'blur' }],
  studentId: [{ required: true, message: '请输入学号', trigger: 'blur' }],
  phone: []
}

const newRoomRow = () => ({ roomId: null, brwtime: '', rtuntime: '', conflict: false, checking: false })

const canConfirm = computed(() => {
  if (selectedRooms.value.length === 0) return false
  return selectedRooms.value.every(r => r.roomId && r.brwtime && r.rtuntime && !r.conflict && !r.checking)
})

const openRoomDialog = () => {
  fetchAllClassrooms()
  roomDialogVisible.value = true
}

const fetchAllClassrooms = async () => {
  try {
    const res = await fetch('/api/classrooms')
    const data = await res.json()
    if (data.success) {
      allClassrooms.value = data.data
      availableRooms.value = data.data
    }
  } catch (e) {
    console.error('获取教室列表失败', e)
  }
}

const addRoom = () => { selectedRooms.value.push(newRoomRow()) }
const removeRoom = (index) => { selectedRooms.value.splice(index, 1) }
const getRoomName = (roomId) => {
  const room = allClassrooms.value.find(r => r.id === roomId)
  return room ? room.name : '未知教室'
}

const onRoomChange = (index) => {
  const row = selectedRooms.value[index]
  row.conflict = false
  if (row.brwtime && row.rtuntime) checkConflict(index)
}

const onTimeChange = async (index) => {
  const row = selectedRooms.value[index]
  if (!row.roomId || !row.brwtime || !row.rtuntime) return

  // Check 3-hour rule
  const borrowTime = new Date(row.brwtime)
  const now = new Date()
  const minTime = new Date(now.getTime() + 3 * 60 * 60 * 1000)
  if (borrowTime < minTime) {
    ElMessage.warning('预约时间需至少提前3小时')
    row.conflict = true
    return
  }
  if (new Date(row.rtuntime) <= borrowTime) {
    ElMessage.warning('归还时间必须晚于预约时间')
    row.conflict = true
    return
  }

  await checkConflict(index)
}

const checkConflict = async (index) => {
  const row = selectedRooms.value[index]
  if (!row.roomId || !row.brwtime || !row.rtuntime) return

  row.checking = true
  row.conflict = false
  try {
    const url = `/api/classrooms/available?borrowTime=${encodeURIComponent(row.brwtime)}&returnTime=${encodeURIComponent(row.rtuntime)}`
    const res = await fetch(url)
    const data = await res.json()
    if (data.success) {
      const availableIds = data.data.map(r => r.id)
      row.conflict = !availableIds.includes(row.roomId)
    }
  } catch (e) {
    console.error('冲突检测失败', e)
  } finally {
    row.checking = false
  }
}

const confirmRoomSelection = () => {
  if (selectedRooms.value.length === 0) {
    ElMessage.warning('请至少选择一间教室')
    return
  }
  roomDialogVisible.value = false
}

const handleSubmit = async () => {
  if (!borrowFormRef.value) return
  await borrowFormRef.value.validate(async (valid) => {
    if (!valid) return

    if (selectedRooms.value.length === 0) {
      ElMessage.warning('请选择至少一间教室')
      return
    }

    // Validation
    for (const room of selectedRooms.value) {
      if (!room.roomId || !room.brwtime || !room.rtuntime) {
        ElMessage.warning('请完善每间教室的时间和选择')
        return
      }
      if (room.conflict) {
        ElMessage.warning('存在冲突的教室，请调整后再提交')
        return
      }
      const borrowTime = new Date(room.brwtime)
      const now = new Date()
      if (borrowTime < new Date(now.getTime() + 3 * 60 * 60 * 1000)) {
        ElMessageBox.alert('教室需至少提前3小时预约，请调整时间', '提示', { confirmButtonText: '确定', type: 'warning' })
        return
      }
    }

    loading.value = true
    try {
      const roomDetails = selectedRooms.value.map(r => ({
        roomId: r.roomId,
        brwtime: r.brwtime,
        rtuntime: r.rtuntime
      }))

      const response = await fetch('/api/rent-records', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: borrowForm.name,
          num: borrowForm.studentId,
          tel: borrowForm.phone,
          roomDetails: roomDetails,
          remark: borrowForm.remark
        })
      })

      const data = await response.json()
      if (data.success) {
        showSuccessModal()
        handleReset()
      } else {
        ElMessage.error(data.message || '提交失败')
      }
    } catch (error) {
      console.error('提交失败:', error)
      ElMessage.error('提交失败，请稍后重试')
    } finally {
      loading.value = false
    }
  })
}

const handleReset = () => {
  if (borrowFormRef.value) borrowFormRef.value.resetFields()
  borrowForm.remark = ''
  selectedRooms.value = []
}

const showSuccessModal = () => {
  successModalVisible.value = true
  if (successModalTimer) clearTimeout(successModalTimer)
  successModalTimer = setTimeout(() => closeSuccessModal(), 3000)
}

const closeSuccessModal = () => {
  successModalVisible.value = false
  if (successModalTimer) { clearTimeout(successModalTimer); successModalTimer = null }
}

onMounted(() => {
  fetchAllClassrooms()
  fetchAnnounce()
})

const fetchAnnounce = async () => {
  try {
    const res = await fetch('/api/announce')
    const data = await res.json()
    if (data.success && data.data) { announceContent.value = data.data; announceVisible.value = true }
  } catch (e) { console.error('获取公告失败', e) }
}

const closeAnnounce = () => { announceVisible.value = false }

const openAnnounce = async () => {
  try {
    const res = await fetch('/api/announce')
    const data = await res.json()
    if (data.success && data.data) announceContent.value = data.data; announceVisible.value = true
    else ElMessage.info('暂无公告')
  } catch (e) { ElMessage.error('获取公告失败') }
}
</script>

<style scoped>
.borrow-application { width: 100%; min-height: 100%; background-color: #fff; padding: 30px; }
.announce-content { min-height: 200px; }
.announce-content :deep(.v-show-content) { padding: 10px; }
.page-header { display: flex; align-items: center; gap: 10px; font-size: 22px; font-weight: 600; color: #303133; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #ebeef5; }
.header-icon { font-size: 26px; color: #409eff; }
.announce-btn { margin-left: auto; background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%); border: none; box-shadow: 0 3px 6px rgba(64, 158, 255, 0.3); transition: all 0.3s ease; padding: 10px 16px; font-size: 14px; font-weight: 500; }
.announce-btn:hover { background: linear-gradient(135deg, #66b1ff 0%, #409eff 100%); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(64, 158, 255, 0.4); }
.borrow-form { max-width: 1200px; }
.button-group { display: flex; justify-content: center; gap: 20px; margin-top: 30px; }

.dialog-tip { color: #909399; font-size: 13px; }
.room-count { margin-left: 16px; color: #606266; font-size: 13px; }
.room-summary { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
.room-tag { display: inline-flex; flex-direction: column; align-items: flex-start; padding: 6px 10px; }
.room-time { font-size: 11px; color: #a0cfff; margin-top: 2px; }

.success-modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 9999; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.success-modal-content { background-color: #fff; border-radius: 12px; padding: 60px 80px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.3); animation: scaleIn 0.3s ease; }
@keyframes scaleIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.success-icon { margin-bottom: 20px; animation: iconBounce 0.5s ease; }
@keyframes iconBounce { 0%,100% { transform: scale(1); } 50% { transform: scale(1.2); } }
.success-title { font-size: 28px; font-weight: 600; color: #303133; margin: 0 0 15px 0; }
.success-text { font-size: 16px; color: #606266; margin: 0; line-height: 1.6; }
:deep(.el-divider__text) { display: flex; align-items: center; gap: 8px; }

@media screen and (max-width: 1600px) {
  .borrow-application { padding: 20px 15px; }
  .page-header { font-size: 18px; margin-bottom: 20px; padding-bottom: 15px; }
  .header-icon { font-size: 22px; }
  .button-group { flex-direction: column; align-items: stretch; }
  :deep(.el-form-item__label) { width: 80px !important; }
  :deep(.el-form-item__content) { margin-left: 60px !important; }
  :deep(.el-select) { width: 100% !important; }
  .success-modal-content { padding: 40px 30px; margin: 20px; }
  .success-title { font-size: 24px; }
  .success-text { font-size: 14px; }
}
</style>
